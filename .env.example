# AI Training Research — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Required for course_updater.py (daily auto-update) and main.py --crew ──

# OpenAI API key — used by GPT-4o mini to evaluate course quality
OPENAI_API_KEY=sk-...

# Serper API key — used to search Google for new courses (serper.dev)
SERPER_API_KEY=...

# ── Optional ──

# OpenAI model for CrewAI research mode (default: gpt-4o)
OPENAI_MODEL_NAME=gpt-4o

# Telegram bot token — for change notifications from course_updater.py
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram chat ID — your personal chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=

# ── Notes ──
# COMPOSIO_API_KEY is NOT used by this project (leftover from another project).
# GitHub Secrets for Actions: OPENAI_API_KEY, SERPER_API_KEY, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID
# generate_website.py and main.py --local work WITHOUT any API keys.
